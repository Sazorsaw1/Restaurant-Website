{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/admin-login",
      "destination": "/admin-login.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/menu",
      "destination": "/api/index"
    },
    {
      "source": "/orders",
      "destination": "/api/index"
    },
    {
      "source": "/orders/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/api/index"
    }
  ]
}
